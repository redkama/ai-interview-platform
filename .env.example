# Root local development environment example

# Backend
DB_URL=jdbc:mariadb://localhost:3306/aimentor?useUnicode=true&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=local-password
JWT_SECRET=replace-with-a-long-secure-secret
JWT_ACCESS_EXPIRATION=1800
JWT_REFRESH_EXPIRATION=1209600
AI_SERVICE_URL=http://localhost:8000

# AI Service
CODEX_API_KEY=your_codex_api_key
CODEX_MODEL=gpt-4.1-mini
USE_MOCK=true
PORT=8000

# Frontend
VITE_API_BASE_URL=http://localhost:8080
VITE_AI_SERVICE_BASE_URL=http://localhost:8000
